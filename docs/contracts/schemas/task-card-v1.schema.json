{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prosmet.local/contracts/task-card-v1.schema.json",
  "title": "ProSmet Task Card v1",
  "type": "object",
  "required": [
    "id",
    "title",
    "role",
    "owner",
    "status",
    "slice",
    "work_package",
    "source_docs",
    "goal",
    "outputs",
    "constraints",
    "forbidden",
    "gate_ids",
    "required_evidence",
    "required_reports",
    "dependencies",
    "handoff_to",
    "acceptance"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^TASK-[0-9A-Z]+$" },
    "title": { "type": "string" },
    "role": { "type": "string" },
    "owner": { "type": "string" },
    "status": { "type": "string" },
    "slice": { "type": "string" },
    "work_package": { "type": "string" },
    "source_docs": { "type": "array", "items": { "type": "string" } },
    "goal": { "type": "string" },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "forbidden": { "type": "array", "items": { "type": "string" } },
    "gate_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "required_evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "required_reports": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "handoff_to": { "type": "array", "items": { "type": "string" } },
    "acceptance": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  },
  "additionalProperties": true
}
