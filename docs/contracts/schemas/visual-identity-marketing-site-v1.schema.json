{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prosmet.local/contracts/visual-identity-marketing-site-v1.schema.json",
  "title": "Visual Identity And Marketing Site Contract Index",
  "type": "object",
  "required": ["contractVersion", "tokenGroups", "marketingSite"],
  "properties": {
    "contractVersion": { "const": "visual-identity-marketing-site.v1" },
    "tokenGroups": {
      "type": "object",
      "required": ["colors"],
      "properties": {
        "colors": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          }
        }
      },
      "additionalProperties": true
    },
    "marketingSite": {
      "type": "object",
      "required": ["app", "routes", "boundaries"],
      "properties": {
        "app": { "const": "apps/marketing" },
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "boundaries": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

